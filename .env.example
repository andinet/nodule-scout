# Copy this file to `.env` and fill in what you need. Everything here is optional.
# A value already exported in your shell always wins over this file.

# --- Claude authentication (choose ONE; only needed to run the orchestrator) ---
# The Claude Agent SDK authenticates either through a logged-in `claude` CLI
# session (run `claude` once to log in) OR through an API key set here. If you
# don't use Claude Code, set your key below:
ANTHROPIC_API_KEY=

# --- Data-source keys (OPTIONAL: only raise rate limits) ---
# The three data sources are free, no-auth public APIs; keys just lift the limits.

# NCBI E-utilities key: raises PubMed rate limit from 3 -> 10 requests/sec.
# Get one at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# openFDA key: raises limit from 240 req/min to 240k/day.
# https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
