# All three data sources are free, no-auth public APIs. Keys are OPTIONAL and only
# raise rate limits. Copy this file to `.env` and fill in if you have them.

# NCBI E-utilities key: raises PubMed rate limit from 3 -> 10 requests/sec.
# Get one at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# openFDA key: raises limit from 240 req/min to 240k/day. https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# The Claude Agent SDK authenticates through the installed, logged-in `claude` CLI
# (Claude Code). If you instead want to use an API key directly, set:
# ANTHROPIC_API_KEY=
